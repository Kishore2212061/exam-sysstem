# ─── Application ───────────────────────────────────────────────────────────────
spring.application.name=exam-portal

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string
spring.data.mongodb.uri=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/examportal?retryWrites=true&w=majority
spring.data.mongodb.database=examportal

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random hex string (e.g. openssl rand -hex 32)
app.jwt.secret=REPLACE_WITH_A_64_CHAR_HEX_SECRET
app.jwt.expiration=86400000

# ─── Server ────────────────────────────────────────────────────────────────────
server.port=8081
server.error.include-message=always
server.error.include-binding-errors=always

# ─── CORS ──────────────────────────────────────────────────────────────────────
app.cors.allowed-origins=http://localhost:5173,http://localhost:3000

# ─── File Upload ───────────────────────────────────────────────────────────────
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# ─── Logging ───────────────────────────────────────────────────────────────────
logging.level.com.examportal=DEBUG
logging.level.org.springframework.security=WARN
